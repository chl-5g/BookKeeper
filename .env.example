# BookKeeper LLM API 配置
# 复制此文件为 .env 并填入真实 key

# --- 必填 ---
API_KEY=sk-your-api-key-here

# --- 可选：默认 DeepSeek，按需切换 ---
# DeepSeek (默认)
API_BASE_URL=https://api.deepseek.com
# 可用模型: deepseek-v4-pro（强推理）, deepseek-v4-flash（快）
MODEL=deepseek-v4-flash

# OpenAI
# API_BASE_URL=https://api.openai.com
# MODEL=gpt-4o

# Anthropic (自动检测，base URL 含 "anthropic" 即切 Messages API)
# API_BASE_URL=https://api.anthropic.com
# MODEL=claude-sonnet-4-6

# 硅基流动 (SiliconFlow)
# API_BASE_URL=https://api.siliconflow.cn
# MODEL=deepseek-ai/DeepSeek-V3

# Groq
# API_BASE_URL=https://api.groq.com
# MODEL=llama-4-maverick-128k
